{
  "expo": {
    "name": "BookLoop",
    "slug": "bookloop-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookloop.mobile",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false,
        "usesAppleSignIn": true
      },
      "infoPlist": {
        "NSCameraUsageDescription": "BookLoop needs camera access to scan books.",
        "NSPhotoLibraryUsageDescription": "BookLoop needs photo library access to upload book images.",
        "NSLocationWhenInUseUsageDescription": "BookLoop uses your location to show nearby books."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.bookloop.mobile",
      "versionCode": 9,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "bookloop",
    "plugins": [
      "./plugins/withAndroidLocalProperties",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563eb",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "BookLoop needs camera access to scan books."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BookLoop needs photo library access to upload book images."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BookLoop uses your location to show nearby books."
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "BookLoop",
              "label": "BookLoop",
              "description": "Browse latest books with details",
              "minWidth": "200dp",
              "minHeight": "150dp",
              "previewImage": "./assets/widget_preview_full.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 43200000
            },
            {
              "name": "BookLoopGrid",
              "label": "BookLoop Gallery",
              "description": "Book covers with prices",
              "minWidth": "200dp",
              "minHeight": "150dp",
              "previewImage": "./assets/widget_preview_grid.png",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 43200000
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "570be636-8f56-4a9e-8998-5021696fdcf2"
      }
    }
  }
}
